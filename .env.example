# Public site URL (used for metadataBase, sitemap, OG tags). Set this in Vercel
# Production & Preview env. Default fallback is the Vercel-provided URL.
NEXT_PUBLIC_SITE_URL=https://kz-buses-live.vercel.app

# MapTiler key for premium basemap tiles in MapLibre. Without it the app falls
# back to a free open-source style.
NEXT_PUBLIC_MAPTILER_KEY=

# Upstash Redis REST endpoint + token — needed for @upstash/ratelimit
# (edge-compatible rate limiting on public POST endpoints). Both must be set
# together; if either is empty, rate-limit middleware no-ops in dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: base URL of the upstream bus-feed service (GTFS-RT proxy / mock).
# If empty the app uses an in-process realistic simulator.
BUS_FEED_BASE_URL=